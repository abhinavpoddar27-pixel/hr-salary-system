# ──────────────────────────────────────────────────
# HR Intelligence & Salary Processing Platform
# Environment Variables
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────────

# Server
NODE_ENV=production
PORT=3000

# JWT — CHANGE THIS to a long random string in production!
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string-minimum-32-chars

# Database — path to directory where hr_system.db will be stored
# On Railway: mount a volume at /data and set this to /data
# Locally: leave empty (defaults to ./data/)
DATA_DIR=/data

# File uploads directory (where XLS files are temporarily stored)
# On Railway: can use the same volume, e.g. /data/uploads
UPLOADS_DIR=/data/uploads

# Admin user — password for the auto-created 'admin' account
# Only used on FIRST startup (when no users exist in the DB)
ADMIN_PASSWORD=YourSecurePassword123!

# CORS — comma-separated list of allowed frontend origins
# Leave empty to allow all origins (not recommended for production)
# Example: https://your-app.up.railway.app,https://your-custom-domain.com
ALLOWED_ORIGINS=
