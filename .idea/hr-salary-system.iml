<?xml version="1.0" encoding="UTF-8"?>
<module type="WEB_MODULE" version="4">
  <component name="NewModuleRootManager">
    <content url="file://$MODULE_DIR$">
      <!-- Heavy / generated dirs — exclude from indexing to keep WebStorm responsive -->
      <excludeFolder url="file://$MODULE_DIR$/node_modules" />
      <excludeFolder url="file://$MODULE_DIR$/backend/node_modules" />
      <excludeFolder url="file://$MODULE_DIR$/frontend/node_modules" />
      <excludeFolder url="file://$MODULE_DIR$/mcp-server/node_modules" />
      <excludeFolder url="file://$MODULE_DIR$/frontend/dist" />
      <excludeFolder url="file://$MODULE_DIR$/frontend/.vite" />
      <excludeFolder url="file://$MODULE_DIR$/coverage" />
      <excludeFolder url="file://$MODULE_DIR$/backend/coverage" />
      <excludeFolder url="file://$MODULE_DIR$/frontend/coverage" />
      <!-- SQLite DB (~75 MB in prod). Use Database tool window, not file indexing. -->
      <excludeFolder url="file://$MODULE_DIR$/data" />
      <excludeFolder url="file://$MODULE_DIR$/backend/data" />
      <!-- Biometric / payroll uploads — large XLS dumps, no value in code search -->
      <excludeFolder url="file://$MODULE_DIR$/uploads" />
      <excludeFolder url="file://$MODULE_DIR$/backend/uploads" />
      <!-- DB backups committed by cron — auto-rotated, not source -->
      <excludeFolder url="file://$MODULE_DIR$/backups" />
      <!-- Build artifacts -->
      <excludeFolder url="file://$MODULE_DIR$/build" />
    </content>
    <orderEntry type="inheritedJdk" />
    <orderEntry type="sourceFolder" forTests="false" />
  </component>
</module>
