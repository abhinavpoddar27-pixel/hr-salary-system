# Backend environment variables — copy to .env for local dev.

# Bug reporter attachment storage. On Railway, this MUST point to a
# persistent volume mount (otherwise files are lost on deploy). Locally,
# defaults to <repo>/uploads/bug-reports/.
# BUG_REPORT_STORAGE_DIR=/app/uploads/bug-reports

# Sarvam AI — speech-to-text translation for bug reports (step 4)
# Get a key from https://dashboard.sarvam.ai/. Model defaults to saaras:v3
# (state-of-the-art, supports mode=translate for Indic → English output).
SARVAM_API_KEY=
SARVAM_MODEL=saaras:v3

# Sarvam batch webhook URL (used when audio > 28s, step 5). In production,
# must match exactly what's registered with Sarvam. In dev, use ngrok or
# rely on the safety-net poller in step 8.
SARVAM_BATCH_WEBHOOK_URL=https://hr-app-production-681b.up.railway.app/api/bug-reports/sarvam-webhook

# Webhook signing secret (step 5–6). Per-report auth token is
# HMAC-SHA256(reportId, this secret). Rotate via new value + redeploy;
# in-flight jobs will fail verification and be resolved by the poller.
SARVAM_WEBHOOK_SECRET=
